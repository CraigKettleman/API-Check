# ─── HTTP Helper ────────────────────────────────────────────────────────

_opener_cache = {}


def _detect_proxy():
    """Detect proxy from env vars or system settings."""
    # 1. Environment variables (all platforms)
    for var in ["HTTPS_PROXY", "https_proxy", "HTTP_PROXY", "http_proxy", "ALL_PROXY", "all_proxy"]:
        val = os.environ.get(var)
        if val:
            return val

    # 2. macOS system proxy
    if sys.platform == "darwin":
        try:
            import subprocess
            result = subprocess.run(
                ["networksetup", "-getsocksfirewallproxy", "Wi-Fi"],
                capture_output=True, text=True, timeout=2,
            )
            if "Enabled: Yes" in result.stdout:
                server, port = None, None
                for line in result.stdout.splitlines():
                    if line.startswith("Server:"):
                        server = line.split(":", 1)[1].strip()
                    elif line.startswith("Port:"):
                        port = line.split(":", 1)[1].strip()
                if server and port:
                    return f"socks5h://{server}:{port}"
        except Exception:
            pass

    return None


def _get_opener():
    if _opener_cache.get("opener"):
        return _opener_cache["opener"]

    proxy_url = _detect_proxy()
    if proxy_url:
        handler = ProxyHandler({"https": proxy_url, "http": proxy_url})
        opener = build_opener(handler)
    else:
        opener = build_opener()

    _opener_cache["opener"] = opener
    return opener


def http_request(url, headers=None, data=None, method="GET", timeout=10):
    req = Request(url, headers=headers or {}, data=data, method=method)
    if data and method == "POST":
        req.add_header("Content-Type", "application/json")
    try:
        opener = _get_opener()
        with opener.open(req, timeout=timeout) as resp:
            return resp.status, resp.read().decode("utf-8", errors="replace")
    except HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8", errors="replace")
        except Exception:
            pass
        return e.code, body
    except URLError as e:
        return 0, str(e.reason)
    except Exception as e:
        return 0, str(e)



def main():
    signal.signal(signal.SIGINT, lambda *_: sys.exit(130))

    if len(sys.argv) == 1:
        print_banner()
        sys.exit(0)

    parser = argparse.ArgumentParser(
        prog="apicheck",
        description="快速检测 AI API Key 是否可用",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
支持 16 个服务商:
  OpenAI, Anthropic, Google Gemini, DeepSeek, Groq,
  Together AI, Mistral, OpenRouter, Moonshot, Zhipu,
  Qwen/DashScope, SiliconFlow, Fireworks, Cohere,
  Mimo Token Plan (tp-), Mimo 订阅计划 (sk-)

示例:
  apicheck sk-xxxx...
  apicheck tp-xxxx...
  apicheck --provider deepseek sk-xxxx...
  apicheck --batch keys.txt
  apicheck -q --batch keys.txt
  echo "sk-xxx" | apicheck -
        """,
    )
    parser.add_argument("keys", nargs="*", help="API Key(s)")
    parser.add_argument("-p", "--provider", help="指定服务商")
    parser.add_argument("-b", "--batch", help="从文件读取 Key (每行一个)")
    parser.add_argument("-j", "--json", action="store_true", help="JSON 输出")
    parser.add_argument("-q", "--quiet", action="store_true", help="只显示可用的 Key")
    parser.add_argument("--parallel", type=int, default=4, help="并发数 (默认 4)")
    parser.add_argument("-v", "--version", action="version", version=f"apicheck {VERSION}")

    args = parser.parse_args()
    keys = list(args.keys)

    # Stdin
    if not sys.stdin.isatty() or "-" in keys:
        stdin_data = sys.stdin.read().strip()
        if stdin_data:
            keys.extend(l.strip() for l in stdin_data.splitlines() if l.strip())
        keys = [k for k in keys if k != "-"]

    # Batch file
    if args.batch:
        try:
            with open(args.batch) as f:
                keys.extend(l.strip() for l in f if l.strip() and not l.startswith("#"))
        except FileNotFoundError:
            print(colorize(f"✗ 文件不存在: {args.batch}", C.RED), file=sys.stderr)
            sys.exit(1)

    if not keys:
        parser.print_help()
        sys.exit(1)

    keys = [k for k in keys if len(k) >= 8]
    if not keys:
        print(colorize("✗ 没有有效的 Key (长度至少 8 字符)", C.RED), file=sys.stderr)
        sys.exit(1)

    # Deduplicate
    seen = set()
    keys = [k for k in keys if k not in seen and not seen.add(k)]

    if not args.json:
        print(colorize(f"\n🔍 apicheck — 检测 {len(keys)} 个 Key\n", C.BOLD))

    def check_one(key):
        return key, test_key(key, args.provider)

    if len(keys) == 1:
        all_results = [(keys[0], check_one(keys[0])[1])]
    else:
        all_results = []
        with concurrent.futures.ThreadPoolExecutor(max_workers=args.parallel) as pool:
            for future in concurrent.futures.as_completed(pool.submit(check_one, k) for k in keys):
                all_results.append(future.result())

    # Restore order
    key_order = {k: i for i, k in enumerate(keys)}
    all_results.sort(key=lambda x: key_order.get(x[0], 999))

    if args.json:
        output = []
        for key, results in all_results:
            output.append({
                "key": mask_key(key),
                "results": [
                    {"provider": r["provider"], "status": r["status"],
                     "message": r["message"], "elapsed": r["elapsed"]}
                    for r in results
                ],
            })
        print(json.dumps(output, ensure_ascii=False, indent=2))
    else:
        working = 0
        for key, results in all_results:
            if args.quiet and not any(r["status"] == "ok" for r in results):
                continue
            print_result(mask_key(key), results)
            if any(r["status"] == "ok" for r in results):
                working += 1

        if working > 0:
            print_neon_confirm(working)

        total = len(keys)
        print(f"{'─' * 60}")
        print(f"共检测 {total} 个 Key，{colorize(str(working), C.GREEN)} 个可用，"
              f"{colorize(str(total - working), C.RED)} 个不可用\n")


if __name__ == "__main__":
    main()

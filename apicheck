def detect_providers(key):
    if key.startswith("sk-ant-"):
        return ["anthropic"]
    if key.startswith("AIza"):
        return ["google"]
    if key.startswith("gsk_"):
        return ["groq"]
    if key.startswith("sk-or-"):
        return ["openrouter"]
    if key.startswith("fw_"):
        return ["fireworks"]
    if key.startswith("tp-"):
        return ["mimo_tp"]
    if key.startswith("sk-"):
        return list(SK_PREFIX_PROVIDERS)
    return list(PROVIDERS.keys())


def test_key(key, specific_provider=None):
    if specific_provider:
        candidates = [specific_provider]
    else:
        candidates = detect_providers(key)

    results = []
    for pid in candidates:
        provider = PROVIDERS[pid]
        test_fn = TEST_DISPATCH[provider["test"]]

        start_time = time.time()
        try:
            status, msg, models = test_fn(key, provider["base_url"])
        except Exception as e:
            status, msg, models = "error", f"✗ 连接失败: {e}", []
        elapsed = time.time() - start_time

        results.append({
            "provider": provider["name"],
            "provider_id": pid,
            "status": status,
            "message": msg,
            "models": models,
            "elapsed": round(elapsed, 2),
        })

        if status in ("ok", "quota"):
            break
        if status == "invalid" and len(candidates) == 1:
            break

    return results


def print_result(key_display, results):
    print(f"\n{'─' * 60}")
    print(f"Key: {colorize(key_display, C.CYAN)}")
    for r in results:
        icon, color = STATUS_DISPLAY.get(r["status"], ("❓", C.YELLOW))
        elapsed_str = colorize(f" ({r['elapsed']}s)", C.DIM)
        line = f"  {icon} {r['provider']}: {r['message']}{elapsed_str}"
        print(colorize(line, color))
        if r["models"]:
            for m in r["models"][:3]:
                mid = m.get("id", m.get("name", "?"))
                print(f"      {colorize('→ ' + str(mid), C.DIM)}")
            if len(r["models"]) > 3:
                extra = len(r["models"]) - 3

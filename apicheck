    "\033[105m\033[97m",  # 亮品红背景 + 白字
]


def neon_glow(text, offset):
    """Per-char background color cycling — matches Java neonGlow()."""
    out = []
    for i, ch in enumerate(text):
        style = NEON_BG[(i + offset) % len(NEON_BG)]
        out.append(f"{style}\033[1m{ch}\033[0m")
    return "".join(out)


def neon(text, offset):
    """Per-char foreground color cycling — matches Java neon()."""
    palette = ["\033[91m", "\033[93m", "\033[92m", "\033[96m", "\033[94m", "\033[95m"]
    out = []
    for i, ch in enumerate(text):
        c = palette[(i + offset) % len(palette)]
        out.append(f"{c}\033[1m{ch}\033[0m")
    return "".join(out)


def print_neon_confirm(working):
    """Neon glow animation — 40 frames, fixed duration."""
    if _NO_COLOR or not sys.stdout.isatty():
        if working > 0:
            print(f"  恭喜可用 — 共 {working} 个 Key 可用!")
        return

    label = "⚡⚡⚡ 恭喜可用 ⚡⚡⚡"
    prefix = "  检测结果: "
    for frame in range(28):
        sys.stdout.write(f"\r{prefix}{neon_glow(label, frame)}")
        sys.stdout.flush()
        time.sleep(0.08)
    if working > 0:
        sys.stdout.write(f"\r{prefix}{neon(label, 0)}\033[2m  — 共 {working} 个 Key 可用!\033[0m\n")
    else:
        sys.stdout.write("\r\033[K")
    sys.stdout.flush()


def mask_key(key):
    if len(key) <= 12:
        return key[:4] + "..." + key[-4:]
    return key[:6] + "..." + key[-4:]



# ─── Response Parsers ──────────────────────────────────────────────────

def _extract_json_msg(body):
    try:
        err = json.loads(body)
        return err.get("error", {}).get("message", "") or str(err)
    except Exception:
        return body[:200]


def _parse_openai(status, body):
    if status == 200:
        try:
            data = json.loads(body)
            models = data.get("data", [])
            return "ok", f"✓ 可用 — 模型数量: {len(models)}", models[:5]
        except json.JSONDecodeError:
            return "ok", "✓ 可用", []
    if status == 401:
        return "invalid", "✗ 无效 Key (401)", []
    if status == 403:
        return "invalid", "✗ 被禁止 (403)", []
    if status == 429:
        return "rate_limited", "⚠ 速率限制 (429)", []
    if status == 402:
        return "quota", "✗ 额度用完 (402)", []
    if status >= 500:
        return "error", f"✗ 服务端错误 ({status})", []
    return "unknown", f"? 响应 {status}: {_extract_json_msg(body)}", []


def _parse_anthropic(status, body):
    if status == 200:
        return "ok", "✓ 可用", []
    if status == 401:
        return "invalid", "✗ 无效 Key (401)", []
    if status == 403:
        return "invalid", "✗ 被禁止 (403)", []
    if status == 429:
        msg = _extract_json_msg(body)
        if "quota" in msg.lower() or "credit" in msg.lower():
            return "quota", f"✗ 额度用完 — {msg}", []
        return "rate_limited", f"⚠ 速率限制 — {msg}", []
    if status == 400:
        msg = _extract_json_msg(body)
        if "authentication" in msg.lower() or "api_key" in msg.lower():
            return "invalid", f"✗ 无效 Key — {msg}", []
        return "ok", "✓ 可用 (Key 有效)", []
    if status == 402:
        return "quota", "✗ 额度用完 (402)", []
    if status >= 500:
        return "error", f"✗ 服务端错误 ({status})", []
    return "unknown", f"? 响应 {status}: {_extract_json_msg(body)}", []


def _parse_gemini(status, body):
    if status == 200:
        try:
            data = json.loads(body)
            models = data.get("models", [])
            return "ok", f"✓ 可用 — 模型数量: {len(models)}", models[:5]
        except json.JSONDecodeError:
            return "ok", "✓ 可用", []
    if status in (400, 401, 403):
        msg = _extract_json_msg(body)
        if "API_KEY_INVALID" in body or "invalid" in msg.lower():
            return "invalid", f"✗ 无效 Key — {msg}", []
        return "invalid", f"✗ 认证失败 ({status}) — {msg}", []
    if status == 429:
        return "rate_limited", "⚠ 速率限制 (429)", []
    if status >= 500:
        return "error", f"✗ 服务端错误 ({status})", []
    return "unknown", f"? 响应 {status}", []


